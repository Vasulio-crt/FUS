{
	"version": 2,
	"routes": [
		{
		"src": "/api/upload",
		"dest": "/api/upload.js",
		"methods": ["POST", "OPTIONS"]
		},
		{
		"src": "/api/files",
		"dest": "/api/files.js",
		"methods": ["GET", "OPTIONS"]
		},
		{
		"src": "/api/delete/(.+)",
		"dest": "/api/delete/[filename].js",
		"methods": ["DELETE", "OPTIONS"]
		},
		{
		"src": "/(.*)",
		"dest": "/public/$1"
		}
	]
}